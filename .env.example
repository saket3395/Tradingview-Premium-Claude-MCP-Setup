# Copy to .env and adjust if needed.
# Port for the local dashboard server.
PORT=4178
# Chrome DevTools Protocol endpoint exposed by TradingView Desktop.
TV_CDP=http://127.0.0.1:9222
# Set to 1 to stop the CLI from bringing TradingView to the foreground (osascript activate).
# The dashboard server never activates TradingView; this only affects `npm run tv`.
TV_NO_ACTIVATE=
# Upstox access-token JSON file ({"access_token":"...", ...}), used ONLY to fetch real NSE
# upper/lower circuit limits at TPO Confirm (India). Analysis only; no orders.
# RECOMMENDED: use an Upstox "Analytics token" — read-only, ~1-year validity, supports the
# Market Quote API, and needs NO daily refresh (generate it once from the Upstox Developer
# Apps page → Analytics tab). A normal OAuth access token also works but expires daily 03:30 IST.
# Absent/expired -> Confirm falls back to the assumed circuit band (tpo.india.circuitBandPct).
UPSTOX_TOKEN_FILE=./data/upstox_token.json
