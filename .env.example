# Copy to .env and adjust if needed.
# Port for the local dashboard server.
PORT=4178
# Chrome DevTools Protocol endpoint exposed by TradingView Desktop.
TV_CDP=http://127.0.0.1:9222
# Set to 1 to stop the CLI from bringing TradingView to the foreground (osascript activate).
# The dashboard server never activates TradingView; this only affects `npm run tv`.
TV_NO_ACTIVATE=
# Upstox access-token JSON file ({"access_token":"...","minted":"<iso>"}), used ONLY to
# fetch real NSE upper/lower circuit limits at TPO Confirm (India). Tokens expire daily
# at 03:30 IST — refresh it like the VCP project does. Absent/stale -> Confirm falls back
# to the assumed circuit band (tpo.india.circuitBandPct) and says so. Analysis only; no orders.
UPSTOX_TOKEN_FILE=/Users/saket/Claude/NSE-VCP-Breakout-29th June/state/upstox_token.json
